# =====================================================
# AUREON GROWTH - Environment Variables
# =====================================================
# Copy this file to .env and fill in the values

# -----------------------------------------------------
# DATABASE (Prisma + SQLite for dev)
# -----------------------------------------------------
# For local development with SQLite (already works out of the box):
DATABASE_URL="file:./dev.db"

# For production with PostgreSQL, change schema.prisma provider then:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# -----------------------------------------------------
# RESEND (Transactional email service)
# -----------------------------------------------------
# Sign up free at https://resend.com (3,000 emails/month free)
# 1. Create an API key in the Resend dashboard
# 2. Paste it below
RESEND_API_KEY=""

# Sender email — MUST come from a verified domain in Resend.
# Until you verify your domain, you can use Resend's test sender:
#   "Aureon Growth <onboarding@resend.dev>"
CONTACT_FROM_EMAIL="Aureon Growth <onboarding@resend.dev>"

# Where internal lead notifications get delivered (YOUR inbox)
CONTACT_TO_EMAIL="hola@aureongrowth.com"

# -----------------------------------------------------
# PUBLIC SITE CONFIG
# -----------------------------------------------------
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_WHATSAPP_NUMBER="573212396665"
NEXT_PUBLIC_CONTACT_EMAIL="hola@aureongrowth.com"

# -----------------------------------------------------
# CAL.COM (Calendar booking — embedded in Contact section)
# -----------------------------------------------------
# Sign up free at https://cal.com
# 1. Create your account (e.g. "lancheros-studio")
# 2. Create an event type (recommended: 60-min "Consultoría Estratégica")
# 3. Set the value below to "your-username/your-event-slug"
# Example: "lancheros-studio/consulta-estrategica-60"
# If empty, the section shows a graceful fallback message.
NEXT_PUBLIC_CAL_LINK=""

# -----------------------------------------------------
# ANALYTICS — GA4 + Microsoft Clarity (both free)
# -----------------------------------------------------
# GA4 setup (5 min):
#   1. Go to https://analytics.google.com → Admin → Create Property
#   2. Add a Web data stream for https://aureongrowth.com
#   3. Copy the Measurement ID (starts with G-)
NEXT_PUBLIC_GA4_ID=""

# Microsoft Clarity — heatmaps + session recordings (5 min, no credit card):
#   1. Go to https://clarity.microsoft.com → Sign in with any account
#   2. New Project → name "Aureon Growth" → site URL
#   3. Copy the Project ID from the install snippet
NEXT_PUBLIC_CLARITY_ID=""
