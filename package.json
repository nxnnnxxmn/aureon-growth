{
  "name": "aureon-growth-services",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "next dev",
    "dev:3000": "next dev --port 3000",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:reset": "prisma migrate reset --force",
    "db:studio": "prisma studio",
    "db:leads": "node -e \"const{PrismaClient}=require('@prisma/client');new PrismaClient().lead.findMany({orderBy:{createdAt:'desc'}}).then(l=>console.table(l.map(x=>({name:x.name,email:x.email,phone:x.phone,service:x.service,createdAt:x.createdAt}))))\"",
    "setup": "npm install --legacy-peer-deps && prisma migrate deploy && prisma generate"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@prisma/client": "^6.19.3",
    "@radix-ui/react-dialog": "^1.1.1",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "framer-motion": "^11.3.8",
    "gsap": "^3.15.0",
    "lucide-react": "^0.408.0",
    "next": "^15.3.0",
    "prisma": "^6.19.3",
    "react": "^19",
    "react-dom": "^19",
    "react-hook-form": "^7.76.1",
    "react-intersection-observer": "^9.13.0",
    "resend": "^6.12.4",
    "tailwind-merge": "^2.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.0.1",
    "eslint": "^8",
    "eslint-config-next": "^15.3.0",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
